# MongoDB Configuration
MONGO_URI=mongodb://admin:afs_secure_pass_2026@mongodb-primary:27017,mongodb-secondary:27017/afs_db?replicaSet=rs0&authSource=admin
MONGO_DATABASE=afs_db
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2

# API Configuration
API_ENDPOINT=http://api-receiver:3001/api/schedules
API_TIMEOUT=30s
RETRY_ATTEMPTS=3
RETRY_DELAY_MS=60s

# Scheduler Configuration (Cron format: minute hour day month weekday)
CRON_SCHEDULE=0 0 * * *
# Examples:
# 0 0 * * * = Every day at midnight
# 0 2 * * * = Every day at 2 AM
# */30 * * * * = Every 30 minutes

# Processing Configuration
BATCH_SIZE=100
MAX_WORKERS=4

# Storage Configuration
AFS_TTL_DAYS=7
ENABLE_XML_ARCHIVE=true
ARCHIVE_PATH=/app/archive

# Logging
LOG_LEVEL=info
LOG_PATH=/app/logs

# Application
NODE_ENV=production
PORT=3000
